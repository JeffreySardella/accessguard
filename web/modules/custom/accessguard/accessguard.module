<?php

/**
 * @file
 * AccessGuard module hooks.
 */

use Drupal\node\NodeInterface;

/**
 * Implements hook_entity_type_alter().
 */
function accessguard_entity_type_alter(array &$entity_types) {
  if (isset($entity_types['node'])) {
    $entity_types['node']->addConstraint('AccessguardGate', []);
  }
}

/**
 * Implements hook_ENTITY_TYPE_insert() for nodes.
 */
function accessguard_node_insert(NodeInterface $node) {
  _accessguard_enqueue_if_published($node);
}

/**
 * Implements hook_ENTITY_TYPE_update() for nodes.
 */
function accessguard_node_update(NodeInterface $node) {
  _accessguard_enqueue_if_published($node);
}

/**
 * Enqueues a scan for a node when it is published.
 *
 * This is what makes a save trigger a re-scan, so violation data tracks the
 * content as it changes (and, with the publish gate, keeps the dashboard
 * current after an editor fixes an issue).
 */
function _accessguard_enqueue_if_published(NodeInterface $node) {
  if (!\Drupal::config('accessguard.settings')->get('rescan_enabled')) {
    return;
  }
  if ($node->isPublished()) {
    \Drupal::queue('accessguard_scan_queue')->createItem(['nid' => (int) $node->id(), 'trigger' => 'save']);
  }
}

/**
 * Implements hook_ENTITY_TYPE_delete() for nodes.
 *
 * Removes the scans, violations, and waivers belonging to a deleted node.
 */
function accessguard_node_delete(NodeInterface $node) {
  $etm = \Drupal::entityTypeManager();
  // Waivers reference the node directly (not a scan), so clean them up even
  // when the node was never scanned. A leftover waiver on a reused node id
  // would silently suppress violations on unrelated content.
  $waiverStorage = $etm->getStorage('accessguard_waiver');
  $waiverIds = $waiverStorage->getQuery()
    ->accessCheck(FALSE)
    ->condition('target_entity_type', 'node')
    ->condition('target_entity_id', $node->id())
    ->execute();
  if ($waiverIds) {
    $waiverStorage->delete($waiverStorage->loadMultiple($waiverIds));
  }
  $scanStorage = $etm->getStorage('accessguard_scan');
  $scanIds = $scanStorage->getQuery()
    ->accessCheck(FALSE)
    ->condition('target_entity_type', 'node')
    ->condition('target_entity_id', $node->id())
    ->execute();
  if (!$scanIds) {
    return;
  }
  $violationStorage = $etm->getStorage('accessguard_violation');
  $violationIds = $violationStorage->getQuery()
    ->accessCheck(FALSE)
    ->condition('scan_id', $scanIds, 'IN')
    ->execute();
  if ($violationIds) {
    $violationStorage->delete($violationStorage->loadMultiple($violationIds));
  }
  $scanStorage->delete($scanStorage->loadMultiple($scanIds));
}

/**
 * Implements hook_cron().
 *
 * Enqueues published nodes that are unscanned or whose latest scan is stale.
 */
function accessguard_cron() {
  $config = \Drupal::config('accessguard.settings');
  if (!$config->get('rescan_enabled')) {
    return;
  }
  $interval = (int) ($config->get('rescan_interval') ?: 86400);
  $batch = (int) ($config->get('rescan_batch') ?: 25);
  $cutoff = \Drupal::time()->getRequestTime() - $interval;

  $entity_type_manager = \Drupal::entityTypeManager();

  // Published node ids.
  $nids = $entity_type_manager->getStorage('node')->getQuery()
    ->accessCheck(FALSE)
    ->condition('status', 1)
    ->execute();
  if (!$nids) {
    return;
  }

  // Latest scan timestamp per node (aggregate query, no entity hydration).
  $latest = \Drupal::service('accessguard.scan_repository')->latestScanCreatedByNode();

  // Timestamps of items cron already enqueued, so frequent cron runs don't
  // pile up duplicate queue items for the same stale node while its scan is
  // still waiting in the queue. A marker expires after one interval, so a
  // lost queue item can't shelve a node forever.
  $state = \Drupal::state();
  $pending = $state->get('accessguard.cron_enqueued', []);
  // Drop markers for nodes that are gone or unpublished.
  $pending = array_intersect_key($pending, array_flip($nids));

  $queue = \Drupal::queue('accessguard_scan_queue');
  $now = \Drupal::time()->getRequestTime();
  $enqueued = 0;
  foreach ($nids as $nid) {
    $last = $latest[$nid] ?? 0;
    if ($last >= $cutoff) {
      continue;
    }
    $marker = $pending[$nid] ?? 0;
    if ($marker > $last && $marker >= $cutoff) {
      // Already enqueued since its last completed scan, within the interval.
      continue;
    }
    $queue->createItem(['nid' => (int) $nid, 'trigger' => 'cron']);
    $pending[$nid] = $now;
    if (++$enqueued >= $batch) {
      break;
    }
  }
  $state->set('accessguard.cron_enqueued', $pending);
}
